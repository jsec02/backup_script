#!/usr/bin/env bash

# ================================================================================
# =                                  SSH-BACKUP                                  =
# ================================================================================

# Backup .ssh directory to dual restic repositories
# - Backs up to local Pi (R1) and cloud B2 (R2)
# - Prunes old snapshots, keeping last 1

set -euo pipefail

# Backup
restic -r "$R1" backup ~/.ssh --tag ssh
restic -r "$R2" backup ~/.ssh --tag ssh

# Prune
restic -r "$R1" forget --tag ssh --keep-last 1 --prune
restic -r "$R2" forget --tag ssh --keep-last 1 --prune

echo "SSH backup completed successfully"
