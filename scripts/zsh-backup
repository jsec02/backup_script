#!/usr/bin/env bash

# ================================================================================
# =                                  ZSH-BACKUP                                  =
# ================================================================================

# Backup zsh config files from local ArchLinux (WSL)
# - .zshenv
# - .zshenv.local
# - .zshrc

set -euo pipefail

# Setup temp directory
TEMP_DIR=~/temp/zsh
mkdir -p "$TEMP_DIR"

echo "Collecting zsh files..."

# Local ArchLinux (WSL)
echo "  → .zshenv..."
cp ~/.zshenv "$TEMP_DIR/.zshenv"

echo "  → .zshenv.local..."
cp ~/.zshenv.local "$TEMP_DIR/.zshenv.local"

echo "  → .zshrc..."
cp ~/.zshrc "$TEMP_DIR/.zshrc"

# Backup to Restic
restic -r "$R1" backup "$TEMP_DIR" --tag zsh
restic -r "$R2" backup "$TEMP_DIR" --tag zsh

# Prune old snapshots
restic -r "$R1" forget --tag zsh --keep-last 1 --prune
restic -r "$R2" forget --tag zsh --keep-last 1 --prune

# Clean up
rm -rf "$TEMP_DIR"

echo "Zsh files backed up successfully"
