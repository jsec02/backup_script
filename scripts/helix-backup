#!/usr/bin/env bash

# ================================================================================
# =                                 HELIX-BACKUP                                 =
# ================================================================================

# Backup Helix configuration to dual restic repositories
# - Backs up to local Pi (R1) and cloud B2 (R2)
# - Prunes old snapshots, keeping last 7

set -euo pipefail

# Backup
restic -r "$R1" backup ~/.config/helix --tag helix
restic -r "$R2" backup ~/.config/helix --tag helix

# Prune
restic -r "$R1" forget --tag helix --keep-last 7 --prune
restic -r "$R2" forget --tag helix --keep-last 7 --prune

echo "Helix backup completed successfully"
